---
// Placeholder for the RestoPOS dashboard UI — pure markup, no data.
const kpis = [
  { label: "Today's sales", value: 'SAR 12,480', delta: '+8.2%' },
  { label: 'Orders', value: '342', delta: '+4.6%' },
  { label: 'Avg. ticket', value: 'SAR 36.50', delta: '+1.9%' },
];

const bars = [42, 58, 45, 70, 62, 84, 76, 92, 68, 88, 74, 96];

const orders = [
  { id: '#2841', table: 'Table 12', total: 'SAR 148.00', status: 'Preparing' },
  { id: '#2840', table: 'Takeaway', total: 'SAR 62.50', status: 'Ready' },
  { id: '#2839', table: 'Table 4', total: 'SAR 214.00', status: 'Served' },
];
---

<div
  role="img"
  aria-label="Preview of the RestoPOS Manager Console showing sales metrics, an hourly sales chart and live orders"
  class="overflow-hidden rounded-2xl bg-charcoal"
>
  <!-- Window chrome -->
  <div class="flex items-center gap-1.5 border-b border-hairline px-4 py-3">
    <span class="size-2.5 rounded-full bg-bone/15"></span>
    <span class="size-2.5 rounded-full bg-bone/15"></span>
    <span class="size-2.5 rounded-full bg-bone/15"></span>
    <span class="ml-3 font-mono text-[11px] tracking-wide text-bone/30">
      RestoPOS — Manager Console
    </span>
    <span
      class="ml-auto rounded-full border border-leaf-bright/30 bg-leaf/15 px-2.5 py-0.5 text-[10px] font-semibold text-leaf-bright"
    >
      ● Live
    </span>
  </div>

  <div class="grid grid-cols-[3rem_1fr] sm:grid-cols-[3.5rem_1fr]">
    <!-- Sidebar -->
    <div class="flex flex-col items-center gap-3 border-r border-hairline py-4">
      {
        [0, 1, 2, 3, 4].map((i) => (
          <span
            class:list={[
              'size-8 rounded-lg',
              i === 0 ? 'brand-gradient' : 'bg-bone/[0.06]',
            ]}
          />
        ))
      }
    </div>

    <!-- Main panel -->
    <div class="space-y-4 p-4 sm:p-5">
      <!-- KPI cards -->
      <div class="grid grid-cols-3 gap-3">
        {
          kpis.map(({ label, value, delta }) => (
            <div class="rounded-xl border border-hairline bg-bone/[0.03] p-3">
              <p class="text-[10px] font-medium uppercase tracking-wider text-bone/35">{label}</p>
              <p class="mt-1 truncate font-mono text-sm font-semibold text-bone sm:text-lg">
                {value}
              </p>
              <p class="mt-0.5 text-[10px] font-semibold text-leaf-bright">{delta}</p>
            </div>
          ))
        }
      </div>

      <div class="grid gap-3 sm:grid-cols-5">
        <!-- Sales chart -->
        <div class="rounded-xl border border-hairline bg-bone/[0.03] p-3 sm:col-span-3">
          <p class="text-[10px] font-medium uppercase tracking-wider text-bone/35">
            Sales by hour
          </p>
          <div class="mt-3 flex h-24 items-end gap-1.5">
            {
              bars.map((h, i) => (
                <span
                  class:list={[
                    'flex-1 rounded-t-sm',
                    i === bars.length - 1
                      ? 'bg-gradient-to-t from-leaf to-gold'
                      : 'bg-bone/10',
                  ]}
                  style={`height:${h}%`}
                />
              ))
            }
          </div>
        </div>

        <!-- Live orders -->
        <div class="rounded-xl border border-hairline bg-bone/[0.03] p-3 sm:col-span-2">
          <p class="text-[10px] font-medium uppercase tracking-wider text-bone/35">Live orders</p>
          <ul class="mt-2.5 space-y-2">
            {
              orders.map(({ id, table, total, status }) => (
                <li class="flex items-center justify-between rounded-lg bg-bone/[0.03] px-2.5 py-2">
                  <div>
                    <p class="text-[11px] font-semibold text-bone/80">
                      {id} · {table}
                    </p>
                    <p class="font-mono text-[10px] text-bone/35">{total}</p>
                  </div>
                  <span
                    class:list={[
                      'rounded-full px-2 py-0.5 text-[9px] font-semibold',
                      status === 'Ready'
                        ? 'bg-leaf/20 text-leaf-bright'
                        : status === 'Preparing'
                          ? 'bg-gold/10 text-gold'
                          : 'bg-bone/10 text-bone/50',
                    ]}
                  >
                    {status}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
