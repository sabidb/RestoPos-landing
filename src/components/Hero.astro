---
import DashboardPreview from './DashboardPreview.astro';
import { APP_URL } from '../config';
---

<section class="relative overflow-x-clip px-6 pb-24 pt-40 md:px-8 md:pt-48">
  <!-- Ambient glow — green and gold, echoing the logo gradient (parallax) -->
  <div
    aria-hidden="true"
    data-parallax="0.2"
    class="pointer-events-none absolute left-1/4 top-0 -z-10 h-[32rem] w-[40rem] -translate-x-1/2 rounded-full bg-leaf/[0.07] blur-[140px] will-change-transform"
  >
  </div>
  <div
    aria-hidden="true"
    data-parallax="-0.12"
    class="pointer-events-none absolute right-1/4 top-10 -z-10 h-[32rem] w-[40rem] translate-x-1/2 rounded-full bg-gold/[0.06] blur-[140px] will-change-transform"
  >
  </div>

  <div class="mx-auto max-w-4xl text-center">
    <p class="mb-6 text-[12px] uppercase tracking-[0.2em] text-gold">
      Restaurant billing, done quietly
    </p>
    <h1 class="text-balance text-display-xl font-extrabold text-bone">
      Every bill,<br />
      <span class="bilingual" data-bilingual>
        <span data-lang="ar" lang="ar">متوافقة تماماً</span>
        <span data-lang="en" aria-hidden="true">fully compliant</span>
      </span><span class="text-gold">.</span>
    </h1>
    <p class="mx-auto mt-8 max-w-md text-balance text-lg leading-relaxed text-bone/60">
      RestoPOS is ZATCA Phase 2-certified point of sale for Saudi restaurants — from the till to
      the Fatoora portal, without the paperwork in between.
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href={APP_URL}
        class="brand-gradient ease-out-quad whitespace-nowrap rounded-full px-8 py-3.5 text-sm font-semibold text-white shadow-[0_8px_28px_rgba(76,122,82,0.35)] transition duration-300 hover:brightness-110"
      >
        Register now
      </a>
      <a
        href="/contact"
        class="ease-out-quad whitespace-nowrap rounded-full border border-bone/20 px-7 py-3.5 text-sm font-medium text-bone transition-colors duration-300 hover:border-bone/50"
      >
        Request a demo
      </a>
      <a
        href="/features"
        class="ease-out-quad whitespace-nowrap px-2 py-3.5 text-sm font-medium text-bone/60 transition-colors duration-300 hover:text-bone"
      >
        See how it works →
      </a>
    </div>
  </div>

  <!-- Central floating container -->
  <div class="mt-20 [perspective:1600px]">
    <div class="animate-float mx-auto max-w-5xl">
      <div
        data-tilt
        class="light-sweep relative overflow-hidden rounded-3xl border border-hairline bg-charcoal-soft/80 p-2 shadow-gold backdrop-blur-xl sm:p-3"
      >
        <DashboardPreview />
      </div>
    </div>
  </div>
</section>

<script>
  // Bilingual word — Arabic and English swap every 2.6s.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  for (const el of document.querySelectorAll('[data-bilingual]')) {
    if (reduceMotion.matches) continue;
    setInterval(() => {
      el.classList.toggle('show-en');
      const showEn = el.classList.contains('show-en');
      el.querySelector('[data-lang="ar"]')?.setAttribute('aria-hidden', String(showEn));
      el.querySelector('[data-lang="en"]')?.setAttribute('aria-hidden', String(!showEn));
    }, 2600);
  }

  // 3D tilt on hover — pointer position maps to a gentle rotateX/rotateY.
  const MAX_TILT = 6; // degrees

  for (const el of document.querySelectorAll<HTMLElement>('[data-tilt]')) {
    el.addEventListener('pointermove', (e) => {
      if (reduceMotion.matches || e.pointerType !== 'mouse') return;
      const rect = el.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      el.classList.add('is-tilting');
      el.style.transform = `rotateX(${(-y * MAX_TILT).toFixed(2)}deg) rotateY(${(x * MAX_TILT).toFixed(2)}deg)`;
    });

    el.addEventListener('pointerleave', () => {
      el.classList.remove('is-tilting');
      el.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  }
</script>
