---
import Layout from '../layouts/Layout.astro';
import { APP_URL } from '../config';

const plans = [
  {
    name: 'Starter',
    price: '99',
    period: '/ month',
    tagline: 'For one location getting started with compliant billing.',
    features: [
      '1 branch, up to 2 devices',
      'ZATCA Phase 2 invoicing — signed, QR-coded, auto-reported to Fatoora',
      'Thermal & PDF receipts',
      'KOT kitchen ticket printing',
      'Close Day reports & Transactions tab',
      'Email support',
    ],
    highlighted: false,
  },
  {
    name: 'Growth',
    price: '149',
    period: '/ month',
    tagline: 'For restaurants growing past a single branch.',
    features: [
      'Up to 3 branches, unlimited devices',
      'Everything in Starter',
      'Manager Console — live "today" counter, Close Day history, WhatsApp share, PDF export',
      'ZATCA status banner',
      'Device-level login approval & access control',
      'Priority chat support',
    ],
    highlighted: true,
  },
  {
    name: 'Pro',
    price: '249',
    period: '/ month',
    tagline: 'For chains and supermarket groups that want it all.',
    features: [
      'Unlimited branches',
      'Everything in Growth',
      'Supermarket / retail mode',
      'Windows desktop app option',
      'Dedicated ZATCA/Fatoora onboarding',
      'Priority support with faster SLA',
    ],
    highlighted: false,
  },
];
---

<Layout title="Pricing — RestoPOS">
  <div class="pb-8 pt-40">
    <section class="mx-auto max-w-4xl px-6 text-center md:px-8">
      <div data-reveal>
        <p class="mb-5 text-[12px] uppercase tracking-[0.2em] text-gold">Pricing</p>
        <h1 class="text-balance text-display-lg font-extrabold text-bone">
          One price, no surprise invoices of our own.
        </h1>
        <p class="mx-auto mt-6 max-w-xl leading-relaxed text-bone/55">
          Every plan includes ZATCA Phase 2 compliance. No setup fees, no per-invoice charges —
          cancel any time.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-20 grid max-w-6xl items-start gap-8 px-6 md:px-8 lg:grid-cols-3">
      {
        plans.map((plan, i) => (
          <div data-reveal style={`--reveal-delay: ${i * 0.1}s`}>
            <div
              class:list={[
                'flex h-full flex-col rounded-2xl p-8',
                plan.highlighted
                  ? 'relative border border-gold/40 bg-charcoal-soft shadow-gold'
                  : 'border border-hairline bg-charcoal-soft/30',
              ]}
            >
              {plan.highlighted && (
                <span class="brand-gradient absolute -top-3 left-8 rounded-full px-3 py-1 text-[10px] font-semibold uppercase tracking-widest text-white">
                  Most chosen
                </span>
              )}
              <h3 class="text-lg font-semibold text-bone">{plan.name}</h3>
              <div class="mt-4 flex items-baseline gap-1">
                <span class="text-display-md font-extrabold text-bone">
                  SAR {plan.price}
                </span>
                <span class="text-sm text-bone/40">{plan.period}</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-bone/50">{plan.tagline}</p>

              <ul class="mt-8 flex flex-1 flex-col gap-3">
                {plan.features.map((f) => (
                  <li class="flex items-start gap-2.5 text-sm text-bone/70">
                    <span class="mt-0.5 text-gold">＋</span>
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href={APP_URL}
                class:list={[
                  'ease-out-quad mt-8 rounded-full px-6 py-3 text-center text-sm font-semibold transition-colors duration-300',
                  plan.highlighted
                    ? 'brand-gradient text-white hover:brightness-110'
                    : 'border border-bone/20 text-bone hover:border-bone/50',
                ]}
              >
                Get started
              </a>
            </div>
          </div>
        ))
      }
    </section>

    <section class="mx-auto mt-24 max-w-3xl px-6 text-center md:px-8">
      <p class="text-sm text-bone/40" data-reveal>
        All prices exclude 15% VAT. Billed monthly in Saudi riyals.<br />
        Manager Console unlocks at Growth; Supermarket mode is a Pro feature.
      </p>
    </section>
  </div>
</Layout>
