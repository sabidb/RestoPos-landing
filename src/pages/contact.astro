---
import Layout from '../layouts/Layout.astro';

const fields = [
  { label: 'Full name', name: 'name' },
  { label: 'Restaurant name', name: 'restaurant' },
];
---

<Layout title="Contact — RestoPOS">
  <div class="pb-8 pt-40">
    <section class="mx-auto max-w-3xl px-6 md:px-8">
      <div data-reveal>
        <p class="mb-5 text-[12px] uppercase tracking-[0.2em] text-gold">Contact</p>
        <h1 class="text-balance text-display-lg font-extrabold text-bone">
          Let's get your first invoice printing.
        </h1>
        <p class="mt-6 max-w-lg leading-relaxed text-bone/55">
          Tell us about your restaurant and we'll set up a demo tailored to your branches,
          printers, and menu.
        </p>
      </div>

      <div data-reveal style="--reveal-delay: 0.15s">
        <div id="contact-success" hidden class="mt-14 rounded-2xl border border-gold/30 p-10 text-center">
          <p class="mb-3 text-sm uppercase tracking-widest text-gold">Received</p>
          <h2 class="text-xl font-semibold text-bone">
            Thank you — we'll reach out within one business day.
          </h2>
        </div>

        <form id="contact-form" class="mt-14 flex flex-col gap-6">
          <div class="grid gap-6 sm:grid-cols-2">
            {
              fields.map(({ label, name }) => (
                <div>
                  <label class="text-xs uppercase tracking-widest text-bone/50" for={name}>
                    {label}
                  </label>
                  <input
                    id={name}
                    name={name}
                    required
                    class="ease-out-quad mt-2 w-full rounded-xl border border-hairline bg-charcoal-soft px-4 py-3 text-bone outline-none transition-colors duration-300 placeholder:text-bone/25 focus:border-gold/50"
                  />
                </div>
              ))
            }
          </div>

          <div>
            <label class="text-xs uppercase tracking-widest text-bone/50" for="phone">
              Phone or WhatsApp
            </label>
            <input
              id="phone"
              name="phone"
              type="tel"
              required
              class="ease-out-quad mt-2 w-full rounded-xl border border-hairline bg-charcoal-soft px-4 py-3 text-bone outline-none transition-colors duration-300 placeholder:text-bone/25 focus:border-gold/50"
            />
          </div>

          <div>
            <label class="text-xs uppercase tracking-widest text-bone/50" for="message">
              What should we know?
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Number of branches, current POS, printer model — anything helps."
              class="ease-out-quad mt-2 w-full resize-none rounded-xl border border-hairline bg-charcoal-soft px-4 py-3 text-bone outline-none transition-colors duration-300 placeholder:text-bone/25 focus:border-gold/50"
            ></textarea>
          </div>

          <button
            type="submit"
            class="brand-gradient ease-out-quad mt-2 self-start rounded-full px-8 py-3.5 text-sm font-semibold text-white transition duration-300 hover:brightness-110"
          >
            Send request
          </button>
        </form>
      </div>
    </section>
  </div>
</Layout>

<script>
  // TODO: wire to a backend (e.g. serverless function or Resend) to deliver this.
  const form = document.getElementById('contact-form');
  const success = document.getElementById('contact-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.hidden = true;
    if (success) success.hidden = false;
  });
</script>
