---
import Layout from '../layouts/Layout.astro';
import DemoCta from '../components/DemoCta.astro';

const steps = [
  {
    n: '01',
    title: 'Order',
    body: 'Dine-in, parcel, or telephone — each order type routes its own kitchen ticket, auto-titled so the kitchen knows the flow at a glance.',
  },
  {
    n: '02',
    title: 'Bill',
    body: 'A ZATCA-compliant invoice generates instantly: signed, QR-coded, and itemized in Arabic and English. Hold it as a draft first if the table isn’t done.',
  },
  {
    n: '03',
    title: 'Report',
    body: 'The invoice is reported to Fatoora in the background through a dedicated reporting queue. Your Close Day report reconciles itself.',
  },
];

const features = [
  {
    title: 'Multi-branch, one account',
    body: 'Run every branch under one tenant with fully isolated data per VAT number, shared reporting, and a single subscription.',
  },
  {
    title: 'Thermal printing that just works',
    body: 'Direct QZ Tray integration — silent printing with no browser dialogs, auto-reconnect so printers never drop mid-shift, tuned for legibility on any thermal paper.',
  },
  {
    title: 'Arabic and English, natively',
    body: 'Every screen, receipt, and report is bilingual by default — not translated as an afterthought.',
  },
  {
    title: 'Smart kitchen tickets',
    body: 'KOTs print the moment an order lands, auto-labelled Telephone, Parcel, or Dine-in based on order type.',
  },
  {
    title: 'Receipt styles with live preview',
    body: 'Four preset bill styles — including bilingual Arabic/English layouts — previewed live and set in thermal-safe fonts.',
  },
  {
    title: 'Windows desktop app',
    body: 'A native desktop wrapper with automatic updates, for restaurants running Windows POS terminals instead of tablets.',
  },
  {
    title: 'Close Day & Transactions',
    body: 'End-of-day archiving that reconciles to the riyal, next to a full transaction log you can audit any time.',
  },
  {
    title: 'Supermarket mode',
    body: 'The same core switches into a barcode-first retail flow for grocery and convenience formats.',
  },
  {
    title: 'Support built in',
    body: 'Live chat inside the admin panel — talk to us without leaving the dashboard, on every plan’s admin tools.',
  },
];
---

<Layout title="Features — RestoPOS">
  <div class="pb-8 pt-40">
    <section class="mx-auto max-w-6xl px-6 md:px-8">
      <div data-reveal>
        <p class="mb-5 text-[12px] uppercase tracking-[0.2em] text-gold">Features</p>
        <h1 class="max-w-2xl text-balance text-display-lg font-extrabold text-bone">
          From the till to Fatoora, in one continuous line.
        </h1>
      </div>
    </section>

    <!-- Sequence — numbered because it IS a real, ordered process -->
    <section class="relative mx-auto mt-24 max-w-6xl px-6 md:px-8">
      <div
        aria-hidden="true"
        class="absolute bottom-4 left-[15px] top-4 w-px bg-gradient-to-b from-leaf/50 via-gold/30 to-transparent md:left-1/2 md:-translate-x-1/2"
      >
      </div>
      <div class="relative grid gap-10 md:grid-cols-3 md:gap-8">
        {
          steps.map((s, i) => (
            <div data-reveal style={`--reveal-delay: ${i * 0.12}s`}>
              <div class="flex gap-5 pl-10 md:flex-col md:gap-0 md:pl-0">
                <span class="absolute left-0 flex h-8 w-8 items-center justify-center rounded-full border border-gold/30 bg-charcoal font-mono text-sm text-gold md:static md:mb-6">
                  {s.n}
                </span>
                <div>
                  <h3 class="text-lg font-semibold text-bone">{s.title}</h3>
                  <p class="mt-2 max-w-xs text-sm leading-relaxed text-bone/55">{s.body}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Feature grid -->
    <section class="mx-auto mt-32 max-w-6xl px-6 md:px-8">
      <h2 class="max-w-lg text-balance text-display-md font-bold text-bone" data-reveal>
        Everything a Saudi restaurant needs, nothing it doesn't.
      </h2>
      <div class="mt-14 grid gap-px overflow-hidden rounded-2xl bg-hairline sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f, i) => (
            <div data-reveal style={`--reveal-delay: ${(i % 3) * 0.08}s`} class="h-full">
              <div class="ease-out-quad h-full bg-charcoal p-8 transition-colors duration-500 hover:bg-charcoal-soft">
                <h3 class="font-semibold text-bone">{f.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-bone/50">{f.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Advanced tools -->
    <section class="mx-auto mt-32 max-w-6xl px-6 md:px-8">
      <div data-reveal>
        <p class="mb-5 text-[12px] uppercase tracking-[0.2em] text-gold">The toolkit</p>
        <h2 class="max-w-xl text-balance text-display-md font-bold text-bone">
          Advanced tools for owners who run the numbers.
        </h2>
      </div>

      <div class="mt-14 grid gap-6 lg:grid-cols-2">
        <!-- Manager Console -->
        <div data-reveal>
          <div class="ease-out-quad h-full rounded-2xl border border-hairline bg-charcoal-soft/40 p-8 transition-colors duration-500 hover:border-gold/30">
            <h3 class="font-semibold text-bone">Manager Console</h3>
            <p class="mt-2 text-sm leading-relaxed text-bone/50">
              A separate live app for owners — installable on any phone. Today's counter ticking
              in real time, Close Day history, one-tap WhatsApp share or PDF export, and a ZATCA
              status banner so compliance is visible at a glance.
            </p>
            <div class="mt-6 rounded-xl border border-hairline bg-charcoal p-4 font-mono text-[11px]">
              <div class="rounded-md border border-leaf-bright/30 bg-leaf/10 px-2.5 py-1 text-center text-leaf-bright">
                ZATCA · CONNECTED
              </div>
              <div class="mt-3 flex items-center justify-between text-bone/40">
                <span>TODAY · ALL BRANCHES</span>
                <span class="text-leaf-bright">● LIVE</span>
              </div>
              <div class="mt-2 flex items-baseline justify-between">
                <span class="text-2xl font-semibold text-bone">SAR 48,210</span>
                <span class="text-leaf-bright">+11.4%</span>
              </div>
              <div class="mt-4 flex gap-2">
                <span class="rounded-md border border-hairline px-2.5 py-1 text-bone/60">↗ WhatsApp</span>
                <span class="rounded-md border border-hairline px-2.5 py-1 text-bone/60">↧ PDF</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Close Day -->
        <div data-reveal style="--reveal-delay: 0.08s">
          <div class="ease-out-quad h-full rounded-2xl border border-hairline bg-charcoal-soft/40 p-8 transition-colors duration-500 hover:border-gold/30">
            <h3 class="font-semibold text-bone">Close Day</h3>
            <p class="mt-2 text-sm leading-relaxed text-bone/50">
              End every shift with a report that reconciles to the riyal — sales, VAT collected,
              and invoice counts, matched against what was reported to Fatoora.
            </p>
            <div class="mt-6 rounded-xl border border-hairline bg-charcoal p-4 font-mono text-[11px] text-bone/60">
              <div class="flex justify-between py-1"><span>Invoices issued</span><span class="text-bone">342</span></div>
              <div class="flex justify-between py-1"><span>VAT collected (15%)</span><span class="text-bone">1,872.30</span></div>
              <div class="flex justify-between py-1"><span>Reported to Fatoora</span><span class="text-leaf-bright">342 / 342 ✓</span></div>
              <div class="mt-2 flex justify-between border-t border-hairline pt-2"><span>Variance</span><span class="text-leaf-bright">SAR 0.00</span></div>
            </div>
          </div>
        </div>

        <!-- Device approval -->
        <div data-reveal>
          <div class="ease-out-quad h-full rounded-2xl border border-hairline bg-charcoal-soft/40 p-8 transition-colors duration-500 hover:border-gold/30">
            <h3 class="font-semibold text-bone">Device-level access control</h3>
            <p class="mt-2 text-sm leading-relaxed text-bone/50">
              A default-deny security model: every till logs in individually, and a new device
              can't bill a single riyal until an owner explicitly approves it.
            </p>
            <div class="mt-6 space-y-2 rounded-xl border border-hairline bg-charcoal p-4 font-mono text-[11px]">
              <div class="flex items-center justify-between">
                <span class="text-bone/60">Till 01 · Front counter</span>
                <span class="text-leaf-bright">APPROVED</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-bone/60">Till 02 · Drive-thru</span>
                <span class="text-leaf-bright">APPROVED</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-bone/60">Tablet 07 · Unknown</span>
                <span class="rounded-md border border-gold/40 px-2 py-0.5 text-gold">PENDING</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Supermarket mode -->
        <div data-reveal style="--reveal-delay: 0.08s">
          <div class="ease-out-quad h-full rounded-2xl border border-hairline bg-charcoal-soft/40 p-8 transition-colors duration-500 hover:border-gold/30">
            <h3 class="font-semibold text-bone">Supermarket mode</h3>
            <p class="mt-2 text-sm leading-relaxed text-bone/50">
              The same core switches into a barcode-first retail flow for grocery and convenience
              formats — same compliance, same reports, different rhythm.
            </p>
            <div class="mt-6 flex items-center gap-4 rounded-xl border border-hairline bg-charcoal p-4">
              <svg viewBox="0 0 60 24" class="h-9 w-24 text-bone/70" aria-hidden="true">
                {[1, 4, 6, 9, 13, 15, 19, 22, 26, 28, 31, 35, 38, 40, 44, 47, 51, 54, 57].map((x, i) => (
                  <rect x={x} y="0" width={i % 3 === 0 ? 2 : 1} height="24" fill="currentColor" />
                ))}
              </svg>
              <div class="font-mono text-[11px]">
                <p class="text-bone">6281000123457</p>
                <p class="text-bone/50">Scanned · SAR 4.50 · VAT incl.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Fatoora onboarding -->
        <div data-reveal>
          <div class="ease-out-quad h-full rounded-2xl border border-hairline bg-charcoal-soft/40 p-8 transition-colors duration-500 hover:border-gold/30">
            <h3 class="font-semibold text-bone">Fatoora onboarding, automated</h3>
            <p class="mt-2 text-sm leading-relaxed text-bone/50">
              Every new client goes through an automated 7-step ZATCA onboarding — from device
              registration to production reporting — handled by our dedicated Fatoora pipeline.
              You supply one portal OTP; we do the rest.
            </p>
            <div class="mt-6 space-y-1.5 rounded-xl border border-hairline bg-charcoal p-4 font-mono text-[11px]">
              <div class="flex items-center justify-between text-bone/40">
                <span>ONBOARDING</span>
                <span class="text-gold">STEP 5 / 7</span>
              </div>
              <div class="mt-2 flex items-center justify-between">
                <span class="text-bone/60">Device registered</span>
                <span class="text-leaf-bright">✓</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-bone/60">Compliance checks passed</span>
                <span class="text-leaf-bright">✓</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-bone/60">Fatoora portal OTP</span>
                <span class="rounded-md border border-gold/40 px-2 py-0.5 text-gold">PENDING</span>
              </div>
            </div>
          </div>
        </div>

        <!-- KOT smart titles -->
        <div data-reveal style="--reveal-delay: 0.08s">
          <div class="ease-out-quad h-full rounded-2xl border border-hairline bg-charcoal-soft/40 p-8 transition-colors duration-500 hover:border-gold/30">
            <h3 class="font-semibold text-bone">Kitchen tickets with smart titles</h3>
            <p class="mt-2 text-sm leading-relaxed text-bone/50">
              KOTs print the moment an order lands and label themselves — Telephone, Parcel, or
              Dine-in — so the kitchen reads the flow before the first line item.
            </p>
            <div class="mt-6 rounded-xl border border-hairline bg-charcoal p-4 font-mono text-[11px]">
              <div class="flex items-center justify-between">
                <span class="font-semibold text-bone">KOT #114 · TELEPHONE</span>
                <span class="text-bone/40">20:42</span>
              </div>
              <div class="mt-2 space-y-0.5 text-bone/60">
                <p>2× Grilled Broast Platter</p>
                <p>1× Bukhari Rice</p>
                <p class="text-bone/40">— extra garlic sauce</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="mt-32">
      <DemoCta />
    </div>
  </div>
</Layout>
